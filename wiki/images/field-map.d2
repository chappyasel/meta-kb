grid-rows: 2

# ─── Row 1: Ingestion ─────────────────────────────────────────

ingestion: Ingestion {
  style.fill: "#f8fafc"
  style.stroke: "#cbd5e1"
  style.border-radius: 12
  style.font-size: 18
  direction: right

  urls: URLs {
    shape: queue
    style.fill: "#f1f5f9"
    style.stroke: "#94a3b8"
    style.font-size: 14
  }

  detect: Platform Detect {
    shape: diamond
    style.fill: "#f1f5f9"
    style.stroke: "#94a3b8"
    style.font-size: 12
  }

  urls -> detect

  twitter: Twitter (Apify) {
    shape: hexagon
    style.fill: "#dbeafe"
    style.stroke: "#3b82f6"
    style.font-size: 12
  }
  github: GitHub (API) {
    shape: hexagon
    style.fill: "#dbeafe"
    style.stroke: "#3b82f6"
    style.font-size: 12
  }
  arxiv: arXiv (Atom) {
    shape: hexagon
    style.fill: "#dbeafe"
    style.stroke: "#3b82f6"
    style.font-size: 12
  }
  article: Article (Defuddle) {
    shape: hexagon
    style.fill: "#dbeafe"
    style.stroke: "#3b82f6"
    style.font-size: 12
  }

  detect -> twitter
  detect -> github
  detect -> arxiv
  detect -> article

  twitter -> github: GH URLs {
    style.stroke-dash: 3
    style.stroke: "#64748b"
    style.font-size: 10
  }
  article -> github: GH URLs {
    style.stroke-dash: 3
    style.stroke: "#64748b"
    style.font-size: 10
  }

  score: LLM Score (Haiku + Sonnet) {
    style.fill: "#fff7ed"
    style.stroke: "#f97316"
    style.font-size: 12
    style.border-radius: 6
  }

  twitter -> score
  github -> score
  arxiv -> score
  article -> score

  raw: "raw/" {
    shape: page
    style.fill: "#fef3c7"
    style.stroke: "#f59e0b"
    style.font-size: 14
    style.bold: true
  }

  score -> raw
}

# ─── Row 2: Compilation (strict linear chain) ─────────────────

compilation: "bun run compile" {
  style.fill: "#f8fafc"
  style.stroke: "#cbd5e1"
  style.border-radius: 12
  style.font-size: 18
  direction: right

  # Strict linear chain — all passes left to right
  p0: "0  Load\n& Index" {
    style.fill: "#f1f5f9"
    style.stroke: "#94a3b8"
    style.font-size: 12
    style.border-radius: 6
  }

  p1a: "1a  Entities\nHaiku x170" {
    style.fill: "#dbeafe"
    style.stroke: "#3b82f6"
    style.font-size: 12
    style.border-radius: 6
  }

  p1b: "1b  Resolve\nSonnet x1" {
    style.fill: "#fff7ed"
    style.stroke: "#f97316"
    style.font-size: 12
    style.border-radius: 6
  }

  p2: "2  Graph\nSonnet x1" {
    style.fill: "#fff7ed"
    style.stroke: "#f97316"
    style.font-size: 12
    style.border-radius: 6
  }

  p3a: "3a  Synthesis\nSonnet x5" {
    style.fill: "#fff7ed"
    style.stroke: "#f97316"
    style.font-size: 12
    style.border-radius: 6
  }

  p3b: "3b  Cards\nSonnet x67" {
    style.fill: "#fff7ed"
    style.stroke: "#f97316"
    style.font-size: 12
    style.border-radius: 6
  }

  p3c: "3c  Claims\nSonnet x5" {
    style.fill: "#fff7ed"
    style.stroke: "#f97316"
    style.font-size: 12
    style.border-radius: 6
  }

  p4: "4  Field Map\nSonnet x1" {
    style.fill: "#fff7ed"
    style.stroke: "#f97316"
    style.font-size: 12
    style.border-radius: 6
  }

  p5: "5  Diagrams\n+ Backlinks" {
    style.fill: "#f1f5f9"
    style.stroke: "#94a3b8"
    style.font-size: 12
    style.border-radius: 6
  }

  p6: "6  Changelog" {
    style.fill: "#f1f5f9"
    style.stroke: "#94a3b8"
    style.font-size: 12
    style.border-radius: 6
  }

  p7: "7  Self-Eval\nHaiku x30" {
    style.fill: "#dbeafe"
    style.stroke: "#3b82f6"
    style.font-size: 12
    style.border-radius: 6
  }

  wiki: "wiki/" {
    shape: page
    style.fill: "#f0fdf4"
    style.stroke: "#22c55e"
    style.font-size: 14
    style.bold: true
  }

  ev: eval-report.json {
    shape: cylinder
    style.fill: "#f8fafc"
    style.stroke: "#64748b"
    style.font-size: 10
  }

  # Strict linear chain
  p0 -> p1a -> p1b -> p2 -> p3a -> p3b -> p3c -> p4 -> p5 -> p6 -> p7

  # Output branches
  p4 -> wiki
  p7 -> ev
}

# Cross-row edges
ingestion.raw -> compilation.p0

compilation.ev -> ingestion.urls: "next cycle" {
  style.stroke-dash: 5
  style.stroke: "#8b5cf6"
  style.font-size: 11
  style.opacity: 0.7
}
