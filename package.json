{
  "name": "meta-kb",
  "version": "0.1.0",
  "description": "A living, LLM-compiled knowledge base about building LLM knowledge bases.",
  "type": "module",
  "scripts": {
    "ingest": "bun run scripts/ingest.ts",
    "ingest:twitter": "bun run scripts/ingest-twitter.ts",
    "ingest:github": "bun run scripts/ingest-github.ts",
    "ingest:arxiv": "bun run scripts/ingest-arxiv.ts",
    "ingest:article": "bun run scripts/ingest-article.ts",
    "research": "bun run scripts/research.ts",
    "diagrams": "bun run scripts/generate-diagrams.ts",
    "screenshots": "bun run scripts/og-wiki-screenshots.ts",
    "og": "bun run scripts/og-screenshot-all.ts && bun run scripts/og-grid.ts",
    "rescore": "bun run scripts/rescore-all.ts",
    "compile": "bun run scripts/compile.ts",
    "lint": "bun run scripts/lint.ts",
    "test": "bun test"
  },
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.66",
    "ai": "^6.0.145",
    "apify-client": "^2.22.3",
    "defuddle": "^0.15.0",
    "gray-matter": "^4.0.3",
    "linkedom": "^0.18.12",
    "puppeteer": "^24.40.0",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "bun-types": "^1.3.11",
    "typescript": "^6.0.2"
  }
}
